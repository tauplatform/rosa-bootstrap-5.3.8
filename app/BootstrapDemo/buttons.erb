<style>
  .button-demo-token {
    font-family: var(--rosa-font-family-mono);
    font-size: 11px;
    line-height: 14px;
    color: var(--rosa-muted);
    word-break: break-word;
  }

  .button-demo-card-row + .button-demo-card-row {
    border-top: 1px solid var(--rosa-border);
  }

  .button-demo-surface {
    border-radius: 20px;
    padding: 16px;
    background: var(--rosa-light-blue-gray);
  }

  .button-demo-surface-dark {
    color: var(--rosa-white);
    background: var(--rosa-black);
  }

  .button-demo-preview .btn {
    min-width: 92px;
  }

  .button-demo-contextual .btn {
    min-width: 73px;
  }

  .button-demo-state-preview .btn {
    pointer-events: none;
  }

  .button-demo-focus-ring {
    box-shadow: 0 0 0 .25rem var(--rosa-blue-20) !important;
  }
</style>

<main class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/app">Rhodes ROSA style demo</a></li>
      <li class="breadcrumb-item active" aria-current="page">ROSA кнопки</li>
    </ol>
  </nav>

  <header class="mb-4">
    <p class="text-uppercase text-body-secondary fw-semibold mb-2">Rhodes ROSA style demo</p>
    <h1 class="h2 mb-2">ROSA кнопки</h1>
    <p class="text-body-secondary mb-0">Страница демонстрирует стили кнопок Rhodes ROSA style: размеры 32/40/48, радиусы 16/12/16, primary, secondary, flat и contextual.</p>
  </header>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Sizes from ROSA SVG</div>
    <div class="card-body d-grid gap-3 button-demo-preview">
      <div>
        <div class="button-demo-token mb-2">Small: 92×32 · radius 16</div>
        <button type="button" class="btn btn-primary btn-sm">Очистить</button>
      </div>
      <div>
        <div class="button-demo-token mb-2">Default: 92×40 · radius 12</div>
        <button type="button" class="btn btn-primary">Очистить</button>
      </div>
      <div>
        <div class="button-demo-token mb-2">Large: 92×48 · radius 16</div>
        <button type="button" class="btn btn-primary btn-lg">Очистить</button>
      </div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Primary</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-primary btn-sm">Очистить</button>
        <button type="button" class="btn btn-primary">Очистить</button>
        <button type="button" class="btn btn-primary btn-lg">Очистить</button>
        <button type="button" class="btn btn-primary" disabled>Очистить</button>
      </div>
      <div class="button-demo-token">Enabled: #3988FF + white text. Disabled на светлой поверхности: #1D1D1D 8% + #5E6067 40%.</div>
      <div class="button-demo-surface button-demo-surface-dark button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-primary">Очистить</button>
        <button type="button" class="btn btn-primary btn-rosa-on-dark" disabled>Очистить</button>
      </div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Secondary neutral</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-secondary btn-sm">Очистить</button>
        <button type="button" class="btn btn-secondary">Очистить</button>
        <button type="button" class="btn btn-secondary btn-lg">Очистить</button>
        <button type="button" class="btn btn-secondary" disabled>Очистить</button>
      </div>
      <div class="button-demo-surface button-demo-surface-dark button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-secondary-neutral">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-neutral-soft">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-neutral-dark">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-neutral-muted">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-neutral-soft" disabled>Очистить</button>
      </div>
      <div class="button-demo-token">Варианты из SVG: white 85%, white 25%, #1E1E21 90%, #5E6067 40%, white 8%.</div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Secondary blue / white</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-secondary-blue btn-sm">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-blue">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-blue-strong">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-blue-strong btn-lg">Очистить</button>
      </div>
      <div class="button-demo-surface button-demo-surface-dark button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-secondary-blue-on-dark btn-sm">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-blue-on-dark">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-blue-on-dark btn-lg">Очистить</button>
      </div>
      <div class="button-demo-token">Фоны из SVG: #3988FF 10% и 20%; текст #3988FF или white 85%.</div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Secondary red</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-secondary-red btn-sm">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-red">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-red-strong">Очистить</button>
        <button type="button" class="btn btn-rosa-secondary-red-strong btn-lg">Очистить</button>
      </div>
      <div class="button-demo-token">В SVG текст красный #E94E4E/#F12B2B. Фон в исходнике был синим 10/20%, поэтому в теме применён более логичный red 10/20%.</div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Flat</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-flat btn-sm">Очистить</button>
        <button type="button" class="btn btn-rosa-flat">Очистить</button>
        <button type="button" class="btn btn-rosa-flat btn-lg">Очистить</button>
        <button type="button" class="btn btn-rosa-flat" disabled>Очистить</button>
      </div>
      <div class="button-demo-surface button-demo-surface-dark button-demo-preview d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-flat-white btn-sm">Очистить</button>
        <button type="button" class="btn btn-rosa-flat-white">Очистить</button>
        <button type="button" class="btn btn-rosa-flat-white btn-lg">Очистить</button>
        <button type="button" class="btn btn-rosa-flat-white" disabled>Очистить</button>
      </div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">Contextual</div>
    <div class="card-body d-grid gap-3">
      <div class="button-demo-surface button-demo-contextual d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-contextual">Очистить</button>
        <button type="button" class="btn btn-rosa-contextual" disabled>Очистить</button>
      </div>
      <div class="button-demo-surface button-demo-surface-dark button-demo-contextual d-flex flex-wrap gap-2 align-items-center">
        <button type="button" class="btn btn-rosa-contextual btn-rosa-contextual-white">Очистить</button>
        <button type="button" class="btn btn-rosa-contextual btn-rosa-contextual-white" disabled>Очистить</button>
      </div>
      <div class="button-demo-token">Contextual из SVG: 73×25 · radius 12.5 · border #1D1D1D/white 8%.</div>
    </div>
  </section>

  <section class="card mb-4">
    <div class="card-header fw-semibold">ROSA states and semantic variants</div>
    <div class="card-body d-grid gap-3">
      <div class="d-flex flex-wrap gap-2 button-demo-preview">
        <button type="button" class="btn btn-primary">Primary</button>
        <button type="button" class="btn btn-secondary">Secondary</button>
        <button type="button" class="btn btn-success">Success</button>
        <button type="button" class="btn btn-danger">Danger</button>
        <button type="button" class="btn btn-warning">Warning</button>
        <button type="button" class="btn btn-info">Info</button>
        <button type="button" class="btn btn-light">Light</button>
        <button type="button" class="btn btn-dark">Dark</button>
        <button type="button" class="btn btn-link">Link</button>
      </div>
      <div class="d-flex flex-wrap gap-2 button-demo-preview">
        <button type="button" class="btn btn-outline-primary">Primary</button>
        <button type="button" class="btn btn-outline-secondary">Secondary</button>
        <button type="button" class="btn btn-outline-danger">Danger</button>
        <button type="button" class="btn btn-outline-dark">Dark</button>
      </div>
      <div class="d-flex flex-wrap gap-2 button-demo-state-preview button-demo-preview">
        <button type="button" class="btn btn-primary active" aria-pressed="true">Active</button>
        <button type="button" class="btn btn-primary button-demo-focus-ring">Focus</button>
        <button type="button" class="btn btn-primary" disabled>Disabled</button>
      </div>
    </div>
  </section>

  <a class="btn btn-outline-secondary" href="/app">
    <i data-feather="arrow-left" class="me-1"></i>
    Назад на главную
  </a>
</main>

